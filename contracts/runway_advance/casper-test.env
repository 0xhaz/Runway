# Odra livenet config for Casper Testnet deploys (bin/deploy.rs).
# Load automatically via: ODRA_CASPER_LIVENET_ENV=casper-test cargo run --bin deploy --features livenet --release
#
# The secret key must be the FUNDED deployer account (= policy signer for the demo).
# Path is relative to the contract dir (contracts/runway_advance).

ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=../../secrets/policy_signer.pem
# Casper 2.0 exposes a single SSE stream at /events (not /events/main).
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.casper.network/events
