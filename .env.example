# ── Casper / RPC ─────────────────────────────────────────────
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK=casper-test

# ── CSPR.cloud (indexer: REST history + Streaming live) ──────
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_STREAMING_URL=wss://streaming.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=

# ── Financing asset (CEP-18 the x402 example uses) ───────────
# G2 [OPEN]: confirm this ASSET_PACKAGE is faucetable on Testnet
ASSET_PACKAGE_HASH=
ASSET_DECIMALS=9

# Merchant account hash (x402 payTo) whose incoming CEP-18 revenue we underwrite.
# When ASSET_PACKAGE_HASH + this are set, /api/assess reads live CSPR.cloud history.
MERCHANT_ACCOUNT_HASH=

# ── Contracts / pools ────────────────────────────────────────
# Prime pool (Runway's own, self-funded, RunwayUSD asset).
RUNWAY_ADVANCE_CONTRACT_HASH=
# Treasury Yield pool (DAO-governed, TDAO asset) — from `deploy_pool` output.
TREASURY_POOL_CONTRACT_HASH=
# TDAO token package (the TreasuryDAO's CEP-18) — used as the Treasury pool asset.
TREASURY_TOKEN_PACKAGE_HASH=
# Illustrative TDAO the DAO can disburse (base units) for the risk agent's sizing.
TREASURY_TDAO_BALANCE=1000000000000000

# ── TreasuryDAO (multi-agent governance for the Treasury pool) ─
TREASURY_DAO_CONTRACT_HASH=
# Directory holding the DAO agent keys (treasury/, risk/, execution/ each w/ secret_key.pem).
DAO_AGENT_KEYS_DIR=../Casper/keys
# Set true to run the FULL live agent-governed flow on Treasury accept
# (create_proposal → approve×2 → execute → open_advance = 5 real txs moving TDAO).
DAO_LIVE=false
# The DAO's current next_id (the orchestrator is the sole proposal creator).
DAO_NEXT_PROPOSAL_ID=3

# ── Policy signer (the ONLY key allowed to call open_advance) ─
# path to a PEM secret key — never commit the actual key
POLICY_SIGNER_SECRET_KEY_PATH=./secrets/policy_signer.pem

# ── Underwriting agent (G3 [OPEN]: hosted for demo) ──────────
ANTHROPIC_API_KEY=
UNDERWRITING_MODEL=claude-opus-4-8

# ── Wallet ───────────────────────────────────────────────────
# The dashboard connects the Casper Wallet browser extension directly
# (window.CasperWalletProvider) — no configuration needed.

# ── x402 reference stack (run locally, points at Testnet) ────
X402_SERVER_URL=http://localhost:4021
X402_FACILITATOR_URL=http://localhost:4022

